#!/bin/sh
# Pre-commit hook v0.87.31: ESLint + быстрые статические тесты + vitest render-тесты.
# НЕ запускает electron-vite build и e2e — они идут в CI (GitHub Actions).
# Цель — ловить ДО коммита: eslint, hook order, размер файлов, scope, TDZ/hook ошибки.

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx)$' | grep -v '\.cjs$' | grep -v '\.test\.' | grep -v 'node_modules' | grep -v 'out/' | grep -v 'main/preloads/')

if [ -n "$STAGED" ]; then
  echo "🔍 ESLint: проверяю $(echo "$STAGED" | wc -l | tr -d ' ') файлов..."
  echo "$STAGED" | xargs npx eslint --max-warnings 0 2>/dev/null
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ ESLint нашёл ошибки! Коммит отменён."
    exit 1
  fi
  echo "✅ ESLint: OK"
fi

echo "🧪 Быстрые статические тесты (hook order, size, scope, structure, mainImports)..."
FAIL=0
for t in hookOrder.test.cjs componentScope.test.cjs fileSizeLimits.test.cjs appStructure.test.cjs mainImports.test.cjs mainRuntime.test.cjs; do
  if [ -f "src/__tests__/$t" ]; then
    node "src/__tests__/$t" > /tmp/pre-commit.log 2>&1
    if [ $? -ne 0 ]; then
      echo ""
      echo "❌ $t упал:"
      tail -15 /tmp/pre-commit.log
      FAIL=1
    fi
  fi
done

if [ $FAIL -eq 1 ]; then
  echo ""
  echo "❌ Статические тесты упали! --no-verify для обхода (НЕ рекомендуется)."
  exit 1
fi
echo "✅ Статические тесты: OK"

# v0.87.60: Проверка здоровья Memory Bank (размеры, версии, ссылки)
# Запускается только если в staged есть файлы из .memory-bank/ или CLAUDE.md / package*.json
MEMORY_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(\.memory-bank/|CLAUDE\.md$|package(-lock)?\.json$)')
if [ -n "$MEMORY_STAGED" ]; then
  if [ -x scripts/check-memory.sh ]; then
    bash scripts/check-memory.sh > /tmp/check-memory.log 2>&1
    if [ $? -ne 0 ]; then
      echo ""
      echo "❌ Memory Bank не прошёл проверку:"
      cat /tmp/check-memory.log
      echo ""
      echo "Исправь и сделай новый commit. --no-verify запрещён без разрешения пользователя."
      exit 1
    fi
    echo "✅ Memory Bank: OK"
  fi
fi

# v0.87.31: Vitest render-тесты — ловят TDZ, hook-order, битые импорты
# Запускаем только если в staged есть .jsx / .vitest файлы (экономим время)
VITEST_CANDIDATES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(jsx|vitest\.(jsx|js))$' | grep -v 'node_modules')
if [ -n "$VITEST_CANDIDATES" ]; then
  echo "🎨 Vitest render-тесты (компоненты)..."
  npx vitest run --reporter=dot > /tmp/vitest-precommit.log 2>&1
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Vitest render-тесты упали:"
    tail -40 /tmp/vitest-precommit.log
    echo ""
    echo "❌ Используйте --no-verify для обхода (НЕ рекомендуется)."
    exit 1
  fi
  echo "✅ Vitest: OK"
fi

echo "✅ Все быстрые проверки прошли — продолжаем коммит"
