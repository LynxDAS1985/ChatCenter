{
  "_comment": "Общие спам-паттерны для preload (CJS) и renderer (ESM). НЕ РЕДАКТИРОВАТЬ вручную — тестируется автоматически.",
  "time": "^\\d{1,2}:\\d{2}(:\\d{2})?$",
  "date": "^\\d{1,2}[./-]\\d{1,2}[./-]\\d{2,4}$",
  "weekdays": "^(вчера|сегодня|yesterday|today|понедельник|вторник|среда|четверг|пятница|суббота|воскресенье|monday|tuesday|wednesday|thursday|friday|saturday|sunday)$",
  "statuses": "^(\\d+\\s*(непрочитанн|новы[хе]?\\s*сообщ)|только\\s+что|online|в\\s+сети|был[аи]?\\s+(в\\s+сети|online)|печата|записыва|набира|пишет|typing|ожидани[ея]\\s+сети|connecting|reconnecting|updating)",
  "outgoing": "^(вы:\\s|you:\\s)",
  "statusSuffix": "\\s+(в\\s+сети|online|offline)\\s*$",
  "agoSuffix": "\\s+назад\\s*$",
  "agoExact": "^(час|минуту?|секунду?)\\s+назад$",
  "calls": "^(сообщение|пропущенный\\s*(вызов|звонок)|входящий\\s*(вызов|звонок)|missed\\s*call|message)$",
  "system": "^(ожидани[ея]\\s+сети|connecting|reconnecting|updating|загрузк[аи]|обновлени[ея]|подключени[ея])",
  "vkMenu": "^(переслать|отметить|скопировать|удалить|выбрать|ответить|пожаловаться|закрепить|редактировать|сообщение)$",
  "vkMenuPartial": "(переслать|отметить как новое|скопировать текст|удалить|выбрать)",
  "whatsappAlt": "^[a-z]+-[a-z-]+(ic-image)?.*$"
}
